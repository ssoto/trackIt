# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
/database/*.db
/database/*.db-shm
/database/*.db-wal

# claude code (local overrides only)
.claude/settings.local.json

# diverger tool artifacts
.diverger-backup/
.diverger-meta.json
.eslintrc.json

# test output
test-results/
playwright-report/
opencode.local.config.ts
.opencode/local-plugins/
