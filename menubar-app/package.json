{
  "name": "trackit-menubar",
  "version": "1.0.0",
  "description": "TrackIt macOS menu bar applet",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --mac dir"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.trackit.menubar",
    "productName": "TrackIt",
    "mac": {
      "target": "dir",
      "identity": null,
      "category": "public.app-category.productivity"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ]
  }
}
